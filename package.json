{
  "name": "@bezel-labs/bezel-kit",
  "version": "0.1.0",
  "type": "module",
  "description": "Convert a W3C Design Tokens (DTCG) file into a scoped variables.css, with one CSS scope per context.",
  "keywords": [
    "design-tokens",
    "dtcg",
    "css-variables",
    "css-custom-properties",
    "theming",
    "style-dictionary"
  ],
  "license": "PolyForm-Shield-1.0.0",
  "author": "Bezel (https://bezel.new)",
  "homepage": "https://github.com/bezel-labs/bezel-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bezel-labs/bezel-kit.git"
  },
  "bugs": {
    "url": "https://github.com/bezel-labs/bezel-kit/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "bin": {
    "bezel": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepare": "husky"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "semantic-release": "^24.2.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "5.9.3"
  }
}
